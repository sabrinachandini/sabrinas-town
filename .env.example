# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sabrinas_town?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/sabrinas_town?schema=public"

# Server
PORT=3000
HOST=0.0.0.0

# Admin authentication
ADMIN_TOKEN="your-secure-admin-token-here"

# Auth.js (next-auth) — generate with: npx auth secret
AUTH_SECRET="your-auth-secret-here"

# Environment
NODE_ENV="development"

# Scoring config version (increment when weights change)
SCORE_CONFIG_VERSION="1.0.0"

# Stripe (billing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_BASIC_MONTHLY="price_..."
STRIPE_PRICE_PLUS_MONTHLY="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
BASE_URL="http://localhost:3000"

# Error monitoring (Sentry)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Admin email (for /admin panel access)
ADMIN_EMAIL=""
