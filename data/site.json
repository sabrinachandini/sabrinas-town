{
  "name": "Sabrina's Town",
  "tagline": "History is for everyone.",
  "description": "An interconnected network of the 75 most important American Revolution tourism towns",
  "version": "1.0.0",
  "branding": {
    "primaryColor": "#1B4D3E",
    "secondaryColor": "#8B4513",
    "accentColor": "#C9A227",
