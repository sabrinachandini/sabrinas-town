  },
  "contact": {
    "email": "hello@sabrinastown.com",
    "support": "support@sabrinastown.com"
  },
  "social": {
    "twitter": "@sabrinastown",
    "instagram": "@sabrinastown"
  },
  "legal": {
    "privacyPolicy": "/legal/privacy",
    "termsOfService": "/legal/terms"
  },
  "network": {
    "totalTowns": 75,
    "launchTowns": 1,
    "targetStates": ["MA", "NY", "PA", "VA", "NJ", "CT", "RI", "NH", "SC", "GA", "NC", "MD", "DE"],
    "badge": {
      "title": "Top 75 Revolutionary Towns",
      "description": "Part of the interconnected network of America's most important Revolutionary sites"
    }
  },
  "features": {
