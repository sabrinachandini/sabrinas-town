      { "id": "preservation", "weight": 0.15, "label": "Preservation Quality" },
      { "id": "accessibility", "weight": 0.10, "label": "Visitor Accessibility" },
      { "id": "interpretation", "weight": 0.15, "label": "Educational Interpretation" },
      { "id": "interconnection", "weight": 0.15, "label": "Network Connections" },
      { "id": "stories", "weight": 0.10, "label": "Story Richness" },
      { "id": "sources", "weight": 0.10, "label": "Source Quality" }
    ],
    "tiers": [
      { "name": "Exceptional", "minScore": 90 },
      { "name": "Excellent", "minScore": 75 },
      { "name": "Notable", "minScore": 60 },
      { "name": "Relevant", "minScore": 40 },
      { "name": "Emerging", "minScore": 0 }
