{
  "name": "sabrinas-town",
  "version": "1.0.0",
  "description": "Agentic interconnected network of American Revolution tourism towns",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "vercel-build": "npx prisma generate || true",
    "db:deploy": "prisma migrate deploy",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "seed": "tsx src/seed/index.ts",
    "validate": "tsc --noEmit && prisma validate && tsx src/seed/index.ts --dry-run",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "generate": "prisma generate"
  },
  "keywords": [
    "american-revolution",
    "tourism",
    "history",
    "education"
  ],
  "author": "Sabrina Chandini",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.10.0",
    "@sentry/node": "^10.40.0",
    "dotenv": "^16.4.1",
    "fastify": "^4.26.0",
    "nanoid": "^5.0.5",
    "pino-pretty": "^13.1.3",
    "stripe": "^20.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
